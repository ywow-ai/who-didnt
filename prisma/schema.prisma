generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Exception {
  id                            String   @id
  strong_id__                   String
  fbid_v2                       String
  pk_id                         String
  pk                            String
  third_party_downloads_enabled Int
  full_name                     String?
  is_private                    Boolean
  is_verified                   Boolean
  profile_pic_id                String?
  profile_pic_url               String?
  username                      String?
  account_badges                String[]
  has_anonymous_profile_picture Boolean
  latest_reel_media             Int
  reel_media_seen_timestamp     Int?
  is_favorite                   Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exception")
}

model Raw {
  id   String @id @default(uuid())
  json Json   @db.JsonB

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("raw")
}
